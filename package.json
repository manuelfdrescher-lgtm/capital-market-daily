{
  "name": "capital-market-daily",
  "version": "1.0.0",
  "description": "Capital Market Daily – automatisiertes Kapitalmarkt-Briefing als statische Zeitung",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate && astro build && npm run search-index",
    "search-index": "pagefind --site dist",
    "preview": "astro preview",
    "validate": "node scripts/validate.mjs",
    "edition": "node scripts/edition.mjs",
    "ingest": "node scripts/ingest.mjs",
    "logos": "node scripts/fetch-logos.mjs",
    "design-qa": "node scripts/design-qa.mjs"
  },
  "dependencies": {
    "@fontsource-variable/source-serif-4": "^5.2.5",
    "@fontsource/archivo-narrow": "^5.2.5",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "astro": "^5.7.0",
    "nodemailer": "^9.0.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "pagefind": "^1.3.0",
    "playwright": "^1.52.0"
  }
}
