---
import "@fontsource/playfair-display/600.css";
import "@fontsource/playfair-display/700.css";
import "@fontsource/playfair-display/800.css";
import "@fontsource-variable/source-serif-4";
import "@fontsource/barlow-condensed/400.css";
import "@fontsource/barlow-condensed/500.css";
import "@fontsource/barlow-condensed/600.css";
import "../styles/global.css";
import { existsSync } from "node:fs";
import { join } from "node:path";
import CompassRose from "../components/CompassRose.astro";
import MastheadLogo from "../components/MastheadLogo.astro";
import { formatDateLong, slotLabel } from "../lib/format.mjs";

// Eigenes Marken-Logo (Vollversion mit Wortmarke) hat Vorrang: dann wird die
// Text-Wortmarke im Kopf durch das Bild ersetzt.
const logoFile = ["masthead-logo.png", "masthead-logo.svg", "masthead-logo.jpg"].find((f) =>
  existsSync(join(process.cwd(), "public", "images", f))
);

interface Props {
  title: string;
  description?: string;
  active?: string;
  edition?: any; // Editions-Metadaten für Datumszeile und Beispiel-Banner
}

const { title, description, active = "", edition } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const nav = [
  { href: `${base}/`, key: "titelseite", label: "Titelseite" },
  { href: `${base}/news/`, key: "news", label: "News" },
  { href: `${base}/politik/`, key: "politik", label: "Politik" },
  { href: `${base}/branchen-monitor/`, key: "branchen-monitor", label: "Branchen-Monitor" },
  { href: `${base}/unternehmen/`, key: "unternehmen", label: "Unternehmen" },
  { href: `${base}/drei-aktien/`, key: "drei-aktien", label: "Drei Aktien" },
  { href: `${base}/lernecke/`, key: "lernecke", label: "Lernecke" },
  { href: `${base}/archiv/`, key: "archiv", label: "Archiv" },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · The Capital Compass</title>
    <meta name="description" content={description ?? "The Capital Compass: a daily briefing on markets, business and the global economy. Bildung, keine Anlageberatung."} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <a class="skip-link" href="#inhalt">Zum Inhalt springen</a>
    <div class="seite">
      <header class="masthead">
        {logoFile ? (
          <a href={`${base}/`} class="masthead__marke" aria-label="The Capital Compass — zur Titelseite">
            <img class="masthead__marke-img" src={`${base}/images/${logoFile}`} alt="The Capital Compass — A Daily Briefing on Markets, Business and the Global Economy" />
          </a>
        ) : (
          <>
            <MastheadLogo width={210} />
            <p class="masthead__the">The</p>
            <p class="masthead__titel"><a href={`${base}/`}>Capital Compass</a></p>
            <p class="masthead__tagline">A Daily Briefing on Markets, Business and the Global Economy</p>
          </>
        )}
        <div class="masthead__doppel" role="presentation"></div>
        {edition && (
          <div class="datumszeile">
            <span>{formatDateLong(edition.date)}</span>
            <span>{slotLabel(edition.slot)} · Ausgabe Nr. {edition.number}</span>
            <span>Für Manuel Drescher</span>
          </div>
        )}
        <nav class="hauptnav" aria-label="Ressorts">
          {nav.map((item) => (
            <a href={item.href} aria-current={active === item.key ? "page" : undefined}>{item.label}</a>
          ))}
        </nav>
        {edition?.isExample && (
          <p class="beispiel-banner">Beispiel-Ausgabe mit erfundenen Demodaten. Keine echten Kurse, keine echten Nachrichten.</p>
        )}
      </header>

      <main id="inhalt">
        <slot />
      </main>

      <footer class="fusszeile">
        <CompassRose class="fusszeile__kompass" size={30} />
        <p class="fusszeile__claim">Insight · Context · Perspective</p>
        <p><strong>Wichtiger Hinweis:</strong> The Capital Compass dient ausschließlich der Bildung und dem Kapitalmarktverständnis. Es ist keine Anlageberatung. Es gibt keine Kauf-, Verkaufs- oder Halteempfehlungen und keine Trading-Signale. Chancen und Risiken werden nur als analytische Lernpunkte dargestellt.</p>
        <p>Jede Zahl dieser Ausgabe ist vor Veröffentlichung gegen unabhängige Quellen geprüft. Quellen mit Tier-Kennzeichnung stehen an jedem Artikel. Unternehmenslogos: Wikimedia Commons, Markenrechte bei den jeweiligen Unternehmen. „Ein Kurs bewegt sich mit der Differenz zwischen Nachricht und Erwartung.“</p>
      </footer>
    </div>
  </body>
</html>
