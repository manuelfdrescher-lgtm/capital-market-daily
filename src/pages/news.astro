---
import Base from "../layouts/Base.astro";
import Article from "../components/Article.astro";
import RessortKopf from "../components/RessortKopf.astro";
import { getLatestEdition } from "../lib/editions.mjs";

const { data } = getLatestEdition();
const artikel = data.articles.filter((a) => a.ressort === "news" || a.ressort === "makro");
---

<Base title="News" active="news" edition={data.edition}>
  <RessortKopf level="h1" titel="News" untertitel="Alle wichtigen Meldungen seit der letzten Ausgabe, priorisiert nach Relevanz und Lernwert." />
  <hr class="ressort-linie" />
  {artikel.length === 0 && <p style="text-align:center">Diese Ausgabe enthält keine separaten News-Artikel.</p>}
  {artikel.map((a) => <Article article={a} />)}
</Base>
