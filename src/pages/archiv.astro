---
import Base from "../layouts/Base.astro";
import { getAllEditions, getLatestEdition } from "../lib/editions.mjs";
import { formatDateLong, slotLabel } from "../lib/format.mjs";

const editions = getAllEditions();
const latest = getLatestEdition();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="Archiv" active="archiv" edition={latest.data.edition}>
  <div class="ressort-kopf">
    <h1 class="ressort-titel">Archiv</h1>
    <p class="ressort-untertitel">Alle Ausgaben mit stabilen URLs. Die Suche durchsucht sämtliche Artikel.</p>
  </div>
  <hr class="ressort-linie" />

  <div class="suche" id="suche"></div>

  <ul class="archiv-liste">
    {editions.map(({ slug, data }) => (
      <li>
        <span>
          <a href={`${base}/ausgabe/${slug}/`} style="font-weight:700; font-size:18px; text-decoration:none">
            {formatDateLong(data.edition.date)} · {slotLabel(data.edition.slot)}
          </a>
          <span class="dek" style="display:block; font-size:14px; margin:2px 0 0">
            {data.articles.find((a) => a.ressort === "titelseite")?.headline}
          </span>
        </span>
        <span class="nummer">Nr. {data.edition.number}{data.edition.isExample ? " · Beispiel" : ""}</span>
      </li>
    ))}
  </ul>
</Base>

<script is:inline define:vars={{ base }}>
  // Pagefind-Suche (nur nach dem Build verfügbar; im Dev-Modus still deaktiviert)
  (async () => {
    try {
      const el = document.getElementById("suche");
      if (!el) return;
      const mod = await import(`${base}/pagefind/pagefind-ui.js`);
      new mod.PagefindUI({ element: "#suche", showSubResults: true, translations: { placeholder: "Ausgaben durchsuchen …", zero_results: "Keine Treffer für [SEARCH_TERM]" } });
    } catch {
      /* Suche steht erst nach dem Build zur Verfügung */
    }
  })();
</script>
