---
import Base from "../layouts/Base.astro";
import BranchenMonitor from "../components/BranchenMonitor.astro";
import RessortKopf from "../components/RessortKopf.astro";
import { getLatestEdition } from "../lib/editions.mjs";

const { data } = getLatestEdition();
---

<Base title="Branchen-Monitor" active="branchen-monitor" edition={data.edition}>
  <RessortKopf level="h1" titel="Branchen-Monitor" untertitel="Alle 11 GICS-Sektoren (Global Industry Classification Standard) in jeder Ausgabe: was der Sektor ist, wie es ihm geht, mit belegtem Tageswert." />
  <hr class="ressort-linie" />
  <BranchenMonitor monitor={data.branchenMonitor} />
</Base>
