---
// Linien-Chart als SVG mit Fadenkreuz und Pin-Funktion:
// Überfahren zeigt gestrichelte Vertikale, Punktmarker und Datum + Wert.
// Ein Klick pinnt einen Punkt an (roter Marker); beim weiteren Überfahren
// zeigt die Anzeige die prozentuale Veränderung seit dem Pin.
// Doppelklick löst den Pin. Kein Framework, reines Inline-SVG + Skript.
import { formatNumberDE, formatDateShort } from "../lib/format.mjs";

interface Props {
  chart: any; // { title, subtitle?, unit, source, series: [{t, v}] }
  id: string;
}
const { chart, id } = Astro.props;

const series = chart.series ?? [];
const W = 640;
const H = 300;
const pad = { top: 14, right: 16, bottom: 34, left: 66 };

const vs = series.map((p) => p.v);
let min = Math.min(...vs);
let max = Math.max(...vs);
if (min === max) { min -= 1; max += 1; }
const range = max - min;
min -= range * 0.06;
max += range * 0.06;

const plotW = W - pad.left - pad.right;
const plotH = H - pad.top - pad.bottom;

const points = series.map((p, i) => ({
  x: pad.left + (i / (series.length - 1)) * plotW,
  y: pad.top + (1 - (p.v - min) / (max - min)) * plotH,
  t: p.t,
  v: p.v,
}));

const path = points.map((p, i) => `${i === 0 ? "M" : "L"}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(" ");
const areaPath = `${path} L${points[points.length - 1].x.toFixed(1)},${(H - pad.bottom).toFixed(1)} L${points[0].x.toFixed(1)},${(H - pad.bottom).toFixed(1)} Z`;

// Y-Gitter: 4 Linien
const gridlines = [0, 1, 2, 3, 4].map((i) => {
  const val = min + ((max - min) * i) / 4;
  return { y: pad.top + (1 - i / 4) * plotH, label: formatNumberDE(val, Math.abs(max - min) < 5 ? 2 : 0) };
});

// X-Beschriftung: erster, mittlerer, letzter Punkt
const xTicks = [0, Math.floor((series.length - 1) / 2), series.length - 1].map((i) => ({
  x: points[i].x,
  label: formatDateShort(series[i].t),
}));

// Daten fürs Interaktions-Skript (Pixelkoordinaten + Rohwerte)
const hoverData = points.map((p) => ({
  x: Number(p.x.toFixed(1)),
  y: Number(p.y.toFixed(1)),
  d: formatDateShort(p.t),
  v: p.v,
}));
const startLabel = `${formatDateShort(series[series.length - 1].t)} · ${formatNumberDE(series[series.length - 1].v)}${chart.unit ?? ""} (letzter Wert)`;
---

<figure class="chart" data-line-chart data-chart-id={id} data-unit={chart.unit ?? ""}>
  <p class="chart__titel">{chart.title}</p>
  {chart.subtitle && <p class="chart__untertitel">{chart.subtitle}</p>}
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label={`Liniendiagramm: ${chart.title}. Werte von ${formatNumberDE(series[0].v)}${chart.unit ?? ""} (${formatDateShort(series[0].t)}) bis ${formatNumberDE(series[series.length - 1].v)}${chart.unit ?? ""} (${formatDateShort(series[series.length - 1].t)}). Details in der Datentabelle unter dem Diagramm.`}>
    {gridlines.map((g) => (
      <g>
        <line class="gitter" x1={pad.left} y1={g.y} x2={W - pad.right} y2={g.y} />
        <text x={pad.left - 8} y={g.y + 4} text-anchor="end" class="achsenlabel">{g.label}</text>
      </g>
    ))}
    <line class="achse" x1={pad.left} y1={H - pad.bottom} x2={W - pad.right} y2={H - pad.bottom} />
    {xTicks.map((t, i) => (
      <text x={t.x} y={H - pad.bottom + 20} text-anchor={i === 0 ? "start" : i === 2 ? "end" : "middle"} class="achsenlabel">{t.label}</text>
    ))}
    <path class="flaeche" d={areaPath} />
    <path class="linie" d={path} />
    <g class="pin" hidden>
      <line class="pin-linie" x1="0" x2="0" y1={pad.top} y2={H - pad.bottom} />
      <circle class="pin-punkt" r="4.5" cx="0" cy="0" />
    </g>
    <g class="fadenkreuz" hidden>
      <line class="fadenkreuz-linie" x1="0" x2="0" y1={pad.top} y2={H - pad.bottom} />
      <circle class="fadenkreuz-punkt" r="4.5" cx="0" cy="0" />
    </g>
    <rect class="hover-flaeche" x={pad.left} y={pad.top} width={plotW} height={plotH} fill="transparent" />
  </svg>
  <p class="chart__anzeige" aria-live="polite">{startLabel}</p>
  <p class="chart__hinweis">Überfahren zeigt Datum und Kurs. Klick pinnt einen Punkt an und misst die Veränderung in Prozent, Doppelklick löst den Pin.</p>
  <figcaption class="chart__quelle">Quelle: {chart.source}</figcaption>
  <details class="aufklapp datentabelle">
    <summary>Datentabelle anzeigen</summary>
    <div class="aufklapp__inhalt">
      <table>
        <thead><tr><th scope="col">Datum</th><th scope="col">Wert{chart.unit ? ` (${chart.unit.trim()})` : ""}</th></tr></thead>
        <tbody>
          {series.map((p) => (
            <tr><td>{formatDateShort(p.t)}</td><td>{formatNumberDE(p.v)}</td></tr>
          ))}
        </tbody>
      </table>
    </div>
  </details>
  <script type="application/json" data-points set:html={JSON.stringify(hoverData)} />
</figure>

<script>
  // Fadenkreuz + Pin für alle Linien-Charts der Seite.
  function initLineCharts() {
    const nf = new Intl.NumberFormat("de-DE", { maximumFractionDigits: 2 });
    const nfPct = new Intl.NumberFormat("de-DE", { minimumFractionDigits: 1, maximumFractionDigits: 1 });

    document.querySelectorAll<HTMLElement>("[data-line-chart]").forEach((fig) => {
      if (fig.dataset.bound) return;
      fig.dataset.bound = "1";
      const svg = fig.querySelector("svg");
      const dataEl = fig.querySelector("script[data-points]");
      const anzeige = fig.querySelector(".chart__anzeige");
      const kreuz = fig.querySelector<SVGGElement>(".fadenkreuz");
      const pinEl = fig.querySelector<SVGGElement>(".pin");
      if (!svg || !dataEl || !anzeige || !kreuz || !pinEl) return;

      const unit = fig.dataset.unit ?? "";
      const points: { x: number; y: number; d: string; v: number }[] = JSON.parse(dataEl.textContent || "[]");
      const kreuzLinie = kreuz.querySelector("line");
      const kreuzPunkt = kreuz.querySelector("circle");
      const pinLinie = pinEl.querySelector("line");
      const pinPunkt = pinEl.querySelector("circle");
      const viewBoxW = svg.viewBox.baseVal.width;
      const startText = anzeige.textContent;
      let pinned: (typeof points)[number] | null = null;

      const fmt = (p: (typeof points)[number]) => `${p.d} · ${nf.format(p.v)}${unit}`;

      function nearest(clientX: number) {
        const rect = svg.getBoundingClientRect();
        const svgX = ((clientX - rect.left) / rect.width) * viewBoxW;
        let best = points[0];
        let bestDist = Infinity;
        for (const p of points) {
          const d = Math.abs(p.x - svgX);
          if (d < bestDist) { bestDist = d; best = p; }
        }
        return best;
      }

      function render(hover: (typeof points)[number] | null) {
        if (pinned && hover && hover !== pinned) {
          const pct = ((hover.v - pinned.v) / pinned.v) * 100;
          const cls = pct >= 0 ? "delta-positiv" : "delta-negativ";
          const sign = pct >= 0 ? "+" : "";
          anzeige.innerHTML = `${fmt(pinned)} → ${fmt(hover)} · <span class="${cls}">${sign}${nfPct.format(pct)} %</span>`;
        } else if (pinned) {
          anzeige.innerHTML = `Pin: ${fmt(pinned)} · zweiten Punkt überfahren für die Veränderung in Prozent`;
        } else if (hover) {
          anzeige.textContent = fmt(hover);
        } else {
          anzeige.textContent = startText;
        }
      }

      function move(clientX: number) {
        const p = nearest(clientX);
        kreuz.removeAttribute("hidden");
        kreuzLinie?.setAttribute("x1", String(p.x));
        kreuzLinie?.setAttribute("x2", String(p.x));
        kreuzPunkt?.setAttribute("cx", String(p.x));
        kreuzPunkt?.setAttribute("cy", String(p.y));
        render(p);
      }

      function setPin(p: (typeof points)[number] | null) {
        pinned = p;
        if (p) {
          pinEl.removeAttribute("hidden");
          pinLinie?.setAttribute("x1", String(p.x));
          pinLinie?.setAttribute("x2", String(p.x));
          pinPunkt?.setAttribute("cx", String(p.x));
          pinPunkt?.setAttribute("cy", String(p.y));
        } else {
          pinEl.setAttribute("hidden", "");
        }
        render(null);
      }

      svg.addEventListener("mousemove", (e) => move(e.clientX));
      svg.addEventListener("touchmove", (e) => {
        if (e.touches[0]) move(e.touches[0].clientX);
      }, { passive: true });
      svg.addEventListener("click", (e) => {
        const p = nearest(e.clientX);
        setPin(pinned === p ? null : p);
        if (pinned) render(p);
      });
      svg.addEventListener("dblclick", () => setPin(null));
      svg.addEventListener("mouseleave", () => {
        kreuz.setAttribute("hidden", "");
        render(null);
      });
    });
  }
  initLineCharts();
  document.addEventListener("astro:page-load", initLineCharts);
</script>
