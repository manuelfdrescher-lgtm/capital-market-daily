---
interface Props {
  tiles: any[];
  stand?: string;
}
const { tiles, stand } = Astro.props;
const arrow = { up: "▲", down: "▼", flat: "◆" };
// Ein einziges Grid mit fester Spaltenzahl (zwei Reihen), damit die
// Trennlinien zwischen den Reihen exakt fluchten. Ist die zweite Reihe
// nicht vollständig gefüllt, übernimmt die letzte Kachel die Restspalten
// (grid-column: span), statt eine graue Leerfläche stehen zu lassen.
const spalten = Math.max(1, Math.ceil(tiles.length / 2));
const zweiteReihe = Math.max(0, tiles.length - spalten);
const luecke = zweiteReihe > 0 ? spalten - zweiteReihe : 0;
---

<section class="marktpanel" aria-label="Märkte im Überblick">
  <div class="marktpanel__kopf">
    <h2 class="marktpanel__titel">Märkte im Überblick</h2>
    {stand && <span class="marktpanel__stand">{stand}</span>}
  </div>
  <div class="marktkacheln" style={`--mk-spalten: ${spalten}`}>
    {tiles.map((t, i) => (
      <div
        class="kachel"
        style={i === tiles.length - 1 && luecke > 0 ? `grid-column: span ${luecke + 1}` : undefined}
      >
        <span class="kachel__label">{t.label}</span>
        <span class="kachel__wert">{t.approx ? "ca. " : ""}{t.value}</span>
        {t.delta && (
          <span class={`kachel__delta kachel__delta--${t.direction}`}>
            {arrow[t.direction]} {t.delta}
          </span>
        )}
        {t.note && <span class="kachel__note">{t.note}</span>}
      </div>
    ))}
  </div>
</section>
